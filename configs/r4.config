frr version 10.5.3
frr defaults traditional

hostname r4

!
interface eth1
 ipv6 address fc00:24::2/64
 ipv6 ospf6 area 0
!
interface eth2
 ipv6 address fc00:34::1/64
 ipv6 ospf6 area 0
!
interface eth3
 ipv6 address fc00:14::2/64
 ipv6 ospf6 area 0
!
interface eth4
 ipv6 address fc00:4::1/64
 ipv6 ospf6 area 0
!
router ospf6
 router-id 4.4.4.4
!
line vty
!